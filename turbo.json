{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": ["VITE_CONVEX_URL", "VITE_CONVEX_SITE_URL", "VITE_SITE_URL", "VITE_DEVULTUR_API_URL"],
      "outputs": ["dist/**", ".output/**", ".vercel/output/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
